# Clinical ITSM Agent — Environment Variables

# Azure AI Foundry
FOUNDRY_PROJECT_ENDPOINT=https://<your-ai-services>.cognitiveservices.azure.com/
FOUNDRY_MODEL=gpt-4o

# Azure AI Search (KB)
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX_NAME=itsd-kb

# ManageEngine MCP Server
# Local dev: http://localhost:8001/mcp
# Production: https://<apim>.azure-api.net/manage-engine-mcp/mcp
MCP_SERVER_URL=http://localhost:8001/mcp

# APIM (leave empty for local dev, set for production)
APIM_SUBSCRIPTION_KEY=

# Cosmos DB (conversation history — leave empty for local file-based history)
COSMOS_ENDPOINT=
COSMOS_DATABASE=agent-framework
COSMOS_CONTAINER=chat-history

# Observability (leave empty for console-only telemetry)
APPLICATIONINSIGHTS_CONNECTION_STRING=
